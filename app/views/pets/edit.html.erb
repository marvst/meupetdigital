<section class="section">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-6">
        <div class="box">
          <h1 class="title">Edit Pet</h1>
          <h2 class="subtitle">Update the information for <%= @pet.name %></h2>
          
          <% if @pet.errors.any? %>
            <div class="notification is-danger">
              <h4><%= pluralize(@pet.errors.count, "error") %> prohibited this pet from being saved:</h4>
              <ul>
                <% @pet.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          
          <%= form_with model: @pet, local: true do |form| %>
            <div class="field">
              <%= form.label :name, class: "label" %>
              <div class="control">
                <%= form.text_field :name, class: "input", placeholder: "Enter pet's name" %>
              </div>
            </div>
            
            <div class="field">
              <%= form.label :species, class: "label" %>
              <div class="control">
                <div class="select is-fullwidth">
                  <%= form.select :species, 
                      options_for_select([
                        ['Dog', 'dog'],
                        ['Cat', 'cat'],
                        ['Bird', 'bird'],
                        ['Fish', 'fish'],
                        ['Rabbit', 'rabbit'],
                        ['Hamster', 'hamster'],
                        ['Guinea Pig', 'guinea_pig'],
                        ['Other', 'other']
                      ], @pet.species),
                      { prompt: "Select species" },
                      { class: "select" }
                  %>
                </div>
              </div>
            </div>
            
            <div class="field">
              <%= form.label :breed, class: "label" %>
              <div class="control">
                <%= form.text_field :breed, class: "input", placeholder: "Enter breed (e.g., Golden Retriever, Persian)" %>
              </div>
            </div>
            
            <div class="field is-grouped">
              <div class="control">
                <%= form.submit "Update Pet", class: "button is-primary" %>
              </div>
              <div class="control">
                <%= link_to "Cancel", pet_path(@pet), class: "button is-light" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
