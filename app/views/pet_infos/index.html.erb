<section class="section">
  <div class="container">
    <div class="level">
      <div class="level-left">
        <div class="level-item">
          <h1 class="title">Contact Information</h1>
          <h2 class="subtitle">for <%= @pet.name %></h2>
        </div>
      </div>
      <div class="level-right">
        <div class="level-item">
          <%= link_to "Add Contact", new_pet_pet_info_path(@pet), class: "button is-primary" %>
        </div>
      </div>
    </div>
    
    <% if @pet_infos.any? %>
      <div class="columns is-multiline">
        <% @pet_infos.each do |info| %>
          <div class="column is-6">
            <div class="card">
              <div class="card-content">
                <div class="media">
                  <div class="media-left">
                    <figure class="image is-48x48">
                      <div class="has-background-info has-text-white has-text-centered" style="width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <span class="has-text-weight-bold"><%= info.channels.first&.first&.upcase || 'C' %></span>
                      </div>
                    </figure>
                  </div>
                  <div class="media-content">
                    <p class="title is-5"><%= info.name %></p>
                    <p class="subtitle is-6"><%= info.channel_labels %>: <%= info.value %></p>
                  </div>
                </div>
              </div>
              
              <footer class="card-footer">
                <%= link_to "Edit", edit_pet_pet_info_path(@pet, info), class: "card-footer-item" %>
                <%= link_to "Delete", pet_pet_info_path(@pet, info), 
                    method: :delete, 
                    data: { confirm: "Are you sure you want to delete this contact?" },
                    class: "card-footer-item has-text-danger" %>
              </footer>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="notification is-info">
        <p>No contact information added yet. Click "Add Contact" to get started!</p>
      </div>
    <% end %>
    
    <div class="mt-4">
      <%= link_to "Back to Pet", pet_path(@pet), class: "button is-light" %>
      <%= link_to "View Public Page", tags_show_path(uuid: @pet.uuid), target: "_blank", class: "button is-info" %>
    </div>
  </div>
</section>
