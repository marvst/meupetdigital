<section class="section">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-6">
        <div class="box">
          <h1 class="title">Add Contact Information</h1>
          <h2 class="subtitle">for <%= @pet.name %></h2>
          
          <% if @pet_info.errors.any? %>
            <div class="notification is-danger">
              <h4><%= pluralize(@pet_info.errors.count, "error") %> prohibited this contact from being saved:</h4>
              <ul>
                <% @pet_info.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          
          <%= form_with model: [@pet, @pet_info], local: true do |form| %>
            <div class="field">
              <%= form.label :name, class: "label" %>
              <div class="control">
                <%= form.text_field :name, class: "input", placeholder: "e.g., Owner's Phone, Emergency Contact" %>
              </div>
            </div>
            
            <div class="field">
              <%= form.label :value, class: "label" %>
              <div class="control">
                <%= form.text_field :value, class: "input", placeholder: "Enter contact value (phone number, email, username, etc.)" %>
              </div>
              <p class="help">
                For WhatsApp, include country code (e.g., +5511999999999)<br>
                For social media, just the username (without @)
              </p>
            </div>
            
            <div class="field">
              <%= form.label :channels, "Contact Types", class: "label" %>
              <div class="control">
                <div class="columns is-multiline">
                  <% PetInfo.channels.each do |channel| %>
                    <div class="column is-4">
                      <label class="checkbox">
                        <%= form.check_box :channels, { multiple: true }, channel, nil %>
                        <%= channel.humanize %>
                      </label>
                    </div>
                  <% end %>
                </div>
              </div>
              <p class="help">
                Select all the ways this contact can be reached
              </p>
            </div>
            
            <div class="field is-grouped">
              <div class="control">
                <%= form.submit "Add Contact", class: "button is-primary" %>
              </div>
              <div class="control">
                <%= link_to "Cancel", pet_path(@pet), class: "button is-light" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
